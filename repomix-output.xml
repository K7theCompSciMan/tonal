                              ▶ Play all
                            </button>
                            <button className="rounded-full bg-red-600/30 hover:bg-red-600/50 text-red-400 text-sm px-4 py-1.5 transition-colors" type="button" onClick={() => void deletePlaylist()}>Delete</button>
                            <button className="rounded-full bg-[#282828] hover:bg-[#3E3E3E] text-[#B3B3B3] text-sm px-4 py-1.5 transition-colors" type="button" onClick={() => setSelectedPlaylist(null)}>← Back</button>
                          </div>
                        </form>
                        <p className="text-[#B3B3B3] text-sm mt-1">{selectedPlaylist.songs.length} tracks</p>
                      </div>
                    </div>

                    {/* Song rows */}
                    {selectedPlaylist.songs.length === 0 ? (
                      <p className="text-[#6A6A6A] text-sm py-8 text-center">No songs in this playlist yet.</p>
                    ) : (
                      <div className="divide-y divide-[#282828] rounded-lg overflow-hidden bg-[#181818]">
                        {selectedPlaylist.songs.map((song, index) => {
                          const isCurrent = nowPlaying?.id === song.id;
                          return (
                            <div
                              key={song.id}
                              className={`group flex items-center gap-3 px-4 py-3 transition-colors ${isCurrent ? "bg-[#282828]" : "hover:bg-[#282828]"}`}
                              onTouchStart={(e) => handleQueueTouchStart(index, e.changedTouches[0].clientX)}
                              onTouchEnd={(e) => handleQueueTouchEnd(index, e.changedTouches[0].clientX)}
                            >
                              <span className="w-6 text-xs text-[#6A6A6A] text-center shrink-0">{index + 1}</span>
                              <div className="w-10 h-10 rounded overflow-hidden shrink-0 bg-[#333]">
                                <img src={song.cover_url || DEFAULT_COVER} alt={song.title} className="w-full h-full object-cover" />
                              </div>
                              <div className="flex-1 min-w-0">
                                <p className={`truncate text-sm font-medium ${isCurrent ? "text-[#1DB954]" : "text-white"}`}>{song.title}</p>
                                <p className="truncate text-xs text-[#B3B3B3]">{song.artist}</p>
                              </div>
                              <div className="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
                                <button className="p-1 text-[#1DB954] hover:text-white rounded hover:bg-[#3E3E3E]" onClick={() => playSong(song)} title="Play"><IconPlay /></button>
                                <button className="px-2 py-1 text-xs text-[#B3B3B3] hover:text-white rounded hover:bg-[#3E3E3E] disabled:opacity-30" onClick={() => moveQueueItem(index, index - 1)} disabled={index === 0}>↑</button>
                                <button className="px-2 py-1 text-xs text-[#B3B3B3] hover:text-white rounded hover:bg-[#3E3E3E] disabled:opacity-30" onClick={() => moveQueueItem(index, index + 1)} disabled={index === selectedPlaylist.songs.length - 1}>↓</button>
                                <button className="px-2 py-1 text-xs text-red-400 hover:text-red-300 rounded hover:bg-[#3E3E3E]" onClick={() => void removeSongFromPlaylist(song.id)}>✕</button>
                              </div>
                            </div>
                          );
                        })}
                      </div>
                    )}
                  </div>
                )}
              </div>
            )}

            {/* ── UPLOAD tab ── */}
            {activeTab === "upload" && (
              <div className="space-y-6">
                <h1 className="text-3xl font-bold">Add Track</h1>
                <div className="rounded-xl bg-[#181818] p-6">
                  <form className="grid gap-3 sm:grid-cols-2" onSubmit={uploadSong}>
                    <input className={inputCls} placeholder="Title *" required value={newSong.title} onChange={(e) => setNewSong({ ...newSong, title: e.target.value })} />
                    <input className={inputCls} placeholder="Artist" value={newSong.artist} onChange={(e) => setNewSong({ ...newSong, artist: e.target.value })} />
                    <input className={inputCls} placeholder="Album" value={newSong.album} onChange={(e) => setNewSong({ ...newSong, album: e.target.value })} />
                    <input className={inputCls} placeholder="Cover image URL" value={newSong.cover_url} onChange={(e) => setNewSong({ ...newSong, cover_url: e.target.value })} />
                    <input className={`${inputCls} sm:col-span-2`} placeholder="Stream URL or YouTube URL *" required value={newSong.stream_url} onChange={(e) => setNewSong({ ...newSong, stream_url: e.target.value })} />
                    <select className={inputCls} value={newSong.source_type} onChange={(e) => setNewSong({ ...newSong, source_type: e.target.value })}>
                      <option value="direct">Direct audio stream</option>
                      <option value="youtube">YouTube</option>
                    </select>
                    <input className={inputCls} placeholder="Genre" value={newSong.genre} onChange={(e) => setNewSong({ ...newSong, genre: e.target.value })} />
                    <input className={inputCls} placeholder="Mood" value={newSong.mood} onChange={(e) => setNewSong({ ...newSong, mood: e.target.value })} />
                    <input className={inputCls} placeholder="Duration (seconds)" type="number" min={1} value={newSong.duration_seconds} onChange={(e) => setNewSong({ ...newSong, duration_seconds: e.target.value })} />
                    <button className="sm:col-span-2 rounded-full bg-[#1DB954] hover:bg-[#1ed760] text-black font-bold py-3 transition-colors" type="submit">
                      Add to catalog
                    </button>
                  </form>
                </div>
              </div>
            )}

            {/* ── SETTINGS tab ── */}
            {activeTab === "settings" && (
              <div className="space-y-6">
                <h1 className="text-3xl font-bold">Settings</h1>
                <div className="rounded-xl bg-[#181818] divide-y divide-[#282828]">
                  {([
                    { key: "persistentQueueOrdering" as const, label: "Persistent queue ordering", desc: "Save playlist queue order changes in Supabase." },
                    { key: "enableSwipeGestures" as const, label: "Swipe gestures (mobile)", desc: "Swipe left to remove, right to play queue item." },
                    { key: "enableNowPlayingView" as const, label: "Now Playing full view", desc: "Enable full-screen Now Playing from the player bar." },
                  ]).map(({ key, label, desc }) => (
                    <div key={key} className="flex items-center justify-between gap-4 px-5 py-4">
                      <div>
                        <p className="font-medium text-white text-sm">{label}</p>
                        <p className="text-xs text-[#6A6A6A] mt-0.5">{desc}</p>
                      </div>
                      <Toggle checked={settings[key]} onChange={(v) => setSettings((p) => ({ ...p, [key]: v }))} />
                    </div>
                  ))}
                </div>
                {/* Account section */}
                <div className="rounded-xl bg-[#181818] px-5 py-4">
                  <p className="text-sm text-[#B3B3B3] mb-3">Signed in as <span className="text-white">{session.user.email}</span></p>
                  <button className="rounded-full bg-red-600/20 hover:bg-red-600/30 text-red-400 font-semibold text-sm px-5 py-2 transition-colors" onClick={signOut}>Sign out</button>
                </div>
              </div>
            )}

          </div>{/* /max-w */}
        </main>{/* /main */}

        {/* ════ RIGHT PANEL: Queue ════ */}
        {showQueuePanel && (
          <aside className="hidden md:flex w-[320px] flex-col bg-[#121212] border-l border-[#282828] shrink-0">
            <div className="flex items-center justify-between px-5 py-4 border-b border-[#282828]">
              <h3 className="font-bold text-white">Queue</h3>
              <button className="text-[#B3B3B3] hover:text-white" onClick={() => setShowQueuePanel(false)}>✕</button>
            </div>
            <div className="flex-1 overflow-y-auto py-2">
              {queue.length === 0 ? (
                <p className="text-[#6A6A6A] text-sm text-center py-8">Queue is empty</p>
              ) : (
                queue.map((song, idx) => {
                  const isCurrent = nowPlaying?.id === song.id;
                  return (
                    <div
                      key={song.id}
                      className={`flex items-center gap-3 px-4 py-2 cursor-pointer transition-colors ${isCurrent ? "bg-[#282828]" : "hover:bg-[#1A1A1A]"}`}
                      onClick={() => playSong(song)}
                    >
                      <span className="w-5 text-xs text-[#6A6A6A] text-center">{idx + 1}</span>
                      <img src={song.cover_url || DEFAULT_COVER} alt={song.title} className="w-9 h-9 rounded object-cover bg-[#333]" />
                      <div className="flex-1 min-w-0">
                        <p className={`truncate text-xs font-medium ${isCurrent ? "text-[#1DB954]" : "text-white"}`}>{song.title}</p>
                        <p className="truncate text-xs text-[#B3B3B3]">{song.artist}</p>
                      </div>
                    </div>
                  );
                })
              )}
            </div>
          </aside>
        )}

      </div>{/* /body flex */}

      {/* ════════════════════════════════════════════════
          NOW PLAYING BAR (fixed bottom, desktop)
      ════════════════════════════════════════════════ */}
      <footer className="hidden md:grid h-[90px] border-t border-[#282828] bg-[#181818] shrink-0 z-20"
        style={{ gridTemplateColumns: "1fr auto 1fr" }}>

        {/* Left: song info */}
        <div className="flex items-center gap-3 px-4">
          {nowPlaying ? (
            <>
              <img src={nowPlaying.cover_url || DEFAULT_COVER} alt={nowPlaying.title} className="w-14 h-14 rounded object-cover bg-[#333] shrink-0" />
              <div className="min-w-0">
                <p className="truncate text-sm font-medium text-white">{nowPlaying.title}</p>
                <p className="truncate text-xs text-[#B3B3B3]">{nowPlaying.artist}</p>
              </div>
            </>
          ) : (
            <p className="text-xs text-[#6A6A6A]">Nothing playing</p>
          )}
        </div>

        {/* Center: controls + seek */}
        <div className="flex flex-col items-center justify-center gap-1 px-4 w-[380px]">
          <div className="flex items-center gap-6">
            <button className="text-[#B3B3B3] hover:text-white transition-colors" onClick={playPrevious}><IconPrev /></button>
            <button
              className="w-9 h-9 rounded-full bg-white hover:scale-105 flex items-center justify-center transition-transform"
              onClick={() => setIsPlaying((v) => !v)}
            >
              <span className="text-black">{isPlaying ? <IconPause /> : <IconPlay />}</span>
            </button>
            <button className="text-[#B3B3B3] hover:text-white transition-colors" onClick={playNext}><IconNext /></button>
          </div>
          <div className="flex items-center gap-2 w-full">
            <span className="text-xs text-[#B3B3B3] w-8 text-right">{formatTime(currentTime)}</span>
            <input
              type="range" min={0} max={duration || 1} value={currentTime}
              onChange={(e) => { const t = Number(e.target.value); setCurrentTime(t); playerRef.current?.seekTo(t, "seconds"); }}
              className="flex-1 h-1 accent-white rounded-full bg-[#4D4D4D] cursor-pointer"
            />
            <span className="text-xs text-[#B3B3B3] w-8">{formatTime(duration)}</span>
          </div>
        </div>

        {/* Right: volume + extras */}
        <div className="flex items-center justify-end gap-3 px-4">
          {settings.enableNowPlayingView && nowPlaying && (
            <button
              className="text-[#B3B3B3] hover:text-white text-xs font-medium px-2 py-1 rounded hover:bg-[#282828] transition-colors"
              onClick={() => setShowNowPlayingExpanded(true)}
            >
              Full view
            </button>
          )}
          <button
            className={`text-[#B3B3B3] hover:text-white transition-colors p-1 rounded ${showQueuePanel ? "text-white" : ""}`}
            onClick={() => setShowQueuePanel((v) => !v)}
            title="Toggle queue"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h12v2H3v-2z" />
            </svg>
          </button>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" className="text-[#B3B3B3]">
            <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z" />
          </svg>
          <input
            type="range" min={0} max={1} step={0.01} value={volume}
            onChange={(e) => setVolume(Number(e.target.value))}
            className="w-24 h-1 accent-white rounded-full bg-[#4D4D4D] cursor-pointer"
          />
          {/* Hidden player */}
          {nowPlaying && (
            <div className="absolute opacity-0 pointer-events-none w-0 h-0 overflow-hidden">
              <ReactPlayer
                ref={playerRef}
                url={streamUrl}
                playing={isPlaying}
                volume={volume}
                width="0" height="0"
                onProgress={({ playedSeconds }) => setCurrentTime(playedSeconds)}
                onDuration={(d) => setDuration(d)}
                onEnded={playNext}
              />
            </div>
          )}
        </div>
      </footer>

      {/* ════════════════════════════════════════════════
          MOBILE MINI-PLAYER
      ════════════════════════════════════════════════ */}
      {nowPlaying && (
        <div
          className="md:hidden fixed bottom-[64px] left-0 right-0 z-30 bg-[#181818] border-t border-[#282828] px-4 py-2 flex items-center gap-3"
          onClick={() => settings.enableNowPlayingView && setShowNowPlayingExpanded(true)}
        >
          {/* Hidden player for mobile */}
          <div className="absolute opacity-0 pointer-events-none w-0 h-0 overflow-hidden">
            <ReactPlayer
              ref={playerRef}
              url={streamUrl}
              playing={isPlaying}
              volume={volume}
              width="0" height="0"
              onProgress={({ playedSeconds }) => setCurrentTime(playedSeconds)}
              onDuration={(d) => setDuration(d)}
              onEnded={playNext}
            />
          </div>
          <img src={nowPlaying.cover_url || DEFAULT_COVER} alt={nowPlaying.title} className="w-10 h-10 rounded object-cover bg-[#333] shrink-0" />
          <div className="flex-1 min-w-0">
            <p className="truncate text-sm font-medium text-white">{nowPlaying.title}</p>
            <p className="truncate text-xs text-[#B3B3B3]">{nowPlaying.artist}</p>
          </div>
          <button className="text-white p-2" onClick={(e) => { e.stopPropagation(); setIsPlaying((v) => !v); }}>
            {isPlaying ? <IconPause /> : <IconPlay />}
          </button>
          <button className="text-[#B3B3B3] p-2" onClick={(e) => { e.stopPropagation(); playNext(); }}>
            <IconNext />
          </button>
        </div>
      )}

      {/* ════════════════════════════════════════════════
          MOBILE TAB BAR
      ════════════════════════════════════════════════ */}
      <nav className="md:hidden fixed bottom-0 left-0 right-0 z-40 h-16 bg-[#181818] border-t border-[#282828] flex">
        {([
          { id: "home" as MobileTab, label: "Home", icon: <IconHome filled={mobileTab === "home"} /> },
          { id: "search" as MobileTab, label: "Search", icon: <IconSearch /> },
          { id: "library" as MobileTab, label: "Library", icon: <IconLibrary /> },
        ]).map(({ id, label, icon }) => (
          <button
            key={id}
            className={`flex-1 flex flex-col items-center justify-center gap-1 text-xs font-medium transition-colors ${mobileTab === id ? "text-white" : "text-[#B3B3B3]"}`}
            onClick={() => { setMobileTab(id); setActiveTab(id); }}
          >
            {icon}
            {label}
          </button>
        ))}
        {/* Upload button */}
        <button
          className={`flex-1 flex flex-col items-center justify-center gap-1 text-xs font-medium transition-colors ${activeTab === "upload" ? "text-[#1DB954]" : "text-[#B3B3B3]"}`}
          onClick={() => { setActiveTab("upload"); }}
        >
          <IconUpload />
          Upload
        </button>
      </nav>

      {/* ════════════════════════════════════════════════
          DESKTOP NAV: Upload + Settings in topbar
      ════════════════════════════════════════════════ */}
      <div className="hidden md:flex fixed top-4 right-4 gap-2 z-10">
        <button
          className={`flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium transition-colors ${activeTab === "upload" ? "bg-[#282828] text-white" : "text-[#B3B3B3] hover:text-white hover:bg-[#282828]"}`}
          onClick={() => setActiveTab(activeTab === "upload" ? "home" : "upload")}
        >
          <IconUpload /> Upload
        </button>
        <button
          className={`flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium transition-colors ${activeTab === "settings" ? "bg-[#282828] text-white" : "text-[#B3B3B3] hover:text-white hover:bg-[#282828]"}`}
          onClick={() => setActiveTab(activeTab === "settings" ? "home" : "settings")}
        >
          <IconSettings /> Settings
        </button>
      </div>

      {/* ════════════════════════════════════════════════
          EXPANDED NOW PLAYING (full screen)
      ════════════════════════════════════════════════ */}
      {showNowPlayingExpanded && nowPlaying && (
        <div
          ref={nowPlayingExpandedRef}
          className="fixed inset-0 z-50 flex flex-col"
          style={{ background: "linear-gradient(180deg, #1a1a2e 0%, #121212 70%)" }}
          onTouchStart={onNPTouchStart}
          onTouchEnd={onNPTouchEnd}
        >
          {/* Top bar */}
          <div className="flex items-center justify-between px-5 pt-10 pb-2">
            <button className="text-[#B3B3B3] hover:text-white p-2" onClick={() => setShowNowPlayingExpanded(false)}>
              <IconChevronDown />
            </button>
            <div className="text-center">
              <p className="text-xs font-semibold text-[#B3B3B3] uppercase tracking-widest">Now Playing</p>
            </div>
            <div className="w-10" />
          </div>

          {/* Album art */}
          <div className="flex justify-center px-10 mt-6">
            <div className="w-full max-w-[280px] aspect-square rounded-2xl overflow-hidden shadow-2xl bg-[#282828]">
              <img src={nowPlaying.cover_url || DEFAULT_COVER} alt={nowPlaying.title} className="w-full h-full object-cover" />
            </div>
          </div>

          {/* Track info */}
          <div className="flex items-center justify-between px-8 mt-8">
            <div className="min-w-0">
              <p className="text-2xl font-bold text-white truncate">{nowPlaying.title}</p>
              <p className="text-[#B3B3B3] truncate">{nowPlaying.artist}</p>
            </div>
          </div>

          {/* Seek bar */}
          <div className="px-8 mt-4">
            <input
              type="range" min={0} max={duration || 1} value={currentTime}
              onChange={(e) => { const t = Number(e.target.value); setCurrentTime(t); playerRef.current?.seekTo(t, "seconds"); }}
              className="w-full h-1 accent-white rounded-full bg-[#4D4D4D] cursor-pointer"
            />
            <div className="flex justify-between text-xs text-[#B3B3B3] mt-1">
              <span>{formatTime(currentTime)}</span>
              <span>{formatTime(duration)}</span>
            </div>
          </div>

          {/* Controls */}
          <div className="flex items-center justify-between px-12 mt-4">
            <button className="text-[#B3B3B3] hover:text-white p-3 transition-colors" onClick={playPrevious}><IconPrev /></button>
            <button
              className="w-16 h-16 rounded-full bg-white hover:scale-105 flex items-center justify-center transition-transform shadow-lg"
              onClick={() => setIsPlaying((v) => !v)}
            >
              <span className="text-black scale-125">{isPlaying ? <IconPause /> : <IconPlay />}</span>
            </button>
            <button className="text-[#B3B3B3] hover:text-white p-3 transition-colors" onClick={playNext}><IconNext /></button>
          </div>

          {/* Lyrics */}
          {(lyrics || lyricsLoading) && (
            <div className="flex-1 overflow-y-auto mx-6 mt-4 rounded-xl bg-[#282828]/60 p-4">
              <p className="text-xs font-semibold uppercase tracking-widest text-[#6A6A6A] mb-3">Lyrics</p>
              {lyricsLoading ? (
                <p className="text-sm text-[#6A6A6A]">Loading lyrics…</p>
              ) : (
                <p className="text-sm text-[#B3B3B3] whitespace-pre-wrap leading-7">{lyrics}</p>
              )}
            </div>
          )}

          <div className="h-8" />
        </div>
      )}

    </div>
  );
}
</file>

<file path="src/lib/supabase.ts">
import { createClient } from "@supabase/supabase-js";

const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
const supabaseAnonKey = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY;

export const hasSupabaseEnv = Boolean(supabaseUrl && supabaseAnonKey);

export const supabase = createClient(
  supabaseUrl ?? "https://placeholder.supabase.co",
  supabaseAnonKey ?? "placeholder-anon-key",
);
</file>

