function SongCard({ song, isCurrent, playlists, onPlay, onAddToPlaylist, userId }: {
  song: DbSong; isCurrent: boolean;
  playlists: DbPlaylist[]; onPlay: () => void;
  onAddToPlaylist: (playlistId: string) => void;
  userId: string;
}) {
  const [showMenu, setShowMenu] = useState(false);
  return (
    <div
      className={`group relative flex items-center gap-3 rounded-md px-4 py-3 cursor-pointer transition-colors
        ${isCurrent ? "bg-[#282828]" : "hover:bg-[#282828]"}`}
      onClick={onPlay}
